  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "http-proxy-middleware": "^3.0.3",
    "turbo": "^2.5.4"
  },
  "packageManager": "npm@10.9.2"
}
